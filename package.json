{
  "name": "markdownx",
  "version": "1.0.0",
  "private": true,
  "description": "Local-First Cross-Platform Note-Taking App with Automerge CRDT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "desktop": "pnpm --filter @markdownx/desktop dev",
    "desktop:build": "pnpm --filter @markdownx/desktop build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
