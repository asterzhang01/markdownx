{
  "name": "@markdownx/editor-web",
  "version": "1.0.0",
  "private": true,
  "description": "Shared web editor for MarkdownX - MDXEditor integration",
  "type": "module",
  "main": "./dist/editor.es.js",
  "module": "./dist/editor.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/editor.es.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/editor-web.css": "./dist/editor-web.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mdxeditor/editor": "^3.20.0",
    "@markdownx/core": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
